# ─── Personal / local ops data ────────────────────────
# Dated incident reports are personal to each environment.
# README.md and EXAMPLE.md are tracked; dated files are not.
docs/incidents/20*.md

# Local audit trail (per-user); CI may produce its own.
ops/audit.jsonl
ops/*.json

# Local secrets loader referenced by docs/runbooks/mcp-config-hygiene.md
.secrets.env

# ─── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# ─── Testing & Coverage ──────────────────────────────
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
.pytest_cache/
.tox/
.nox/
junit.xml
results/

# ─── Type checking ───────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ─── Virtual environments ────────────────────────────
.venv/
venv/
env/
ENV/
.env
!.env.example

# ─── ML artifacts (never commit models or data) ──────
models/
*.joblib
*.pkl
*.pickle
*.h5
*.pt
*.pth
*.onnx
data/raw/
data/processed/
data/interim/
mlruns/
mlflow.db
artifacts/

# ─── Jupyter ─────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Infrastructure state (never commit) ─────────────
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfvars
!terraform.tfvars.example

# ─── Docker ──────────────────────────────────────────
.docker/

# ─── IDE / OS ─────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Secrets & credentials ───────────────────────────
*.pem
*.key
*.p12
secrets/
credentials/
service-account*.json
gcp-sa-key.json
aws-credentials

# ─── Reports & logs ──────────────────────────────────
logs/
*.log
reports/
*.csv.gz

# Reports v1 (ADR-023 F6) — track the canonical directory layout
# (.gitkeep per type) but never commit actual report payloads.
!ops/reports/
!ops/reports/release/
!ops/reports/drift/
!ops/reports/training/
!ops/reports/incident/
!ops/reports/**/.gitkeep
ops/reports/**/*.json

# ─── DVC ─────────────────────────────────────────────
/tmp/

# ─── Scaffolder scratch output ───────────────────────
# new-service.sh writes to <PROJECT_ROOT>/<ServiceName>. When the
# scaffolder is invoked from inside THIS repo (e.g., during local
# smoke testing), the scaffolded service ends up here. These are
# throwaway artefacts — never commit.
TestSvc/
ScaffoldSmoke*/
_scaffold_scratch/

# ─── PRIVATE ─────────────────────────────────────────

AUDIOVISUAL_CONTENT.md

# Local alertmanager binaries (S2-4 amtool runbook work)
alertmanager-*/
alertmanager-*.tar.gz

# ADR-023 — adopter-specific context files are NEVER committed.
# Example files at `templates/config/*_context.example.yaml` are fine;
# the `.local.yaml` variants contain adopter-specific business data and
# live only on the adopter's workstation (and in Secret Manager for
# runtime consumption).
*_context.local.yaml
*_context.*.local.yaml
*_context.local.*.yaml

# Codex live MCP config — adopter-specific, contains credentials.
# Only `.codex/mcp.example.json` is tracked.
.codex/mcp.json
